@page
@model FootballHub.Pages.Account.RegisterModel
@{ ViewData["Title"] = "Registrazione"; }

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card shadow-sm">
            <div class="card-header fw-semibold text-white" style="background-color:#1a7a3c;">Crea un account</div>
            <div class="card-body">
                @if (!string.IsNullOrEmpty(Model.Errore))
                { <div class="alert alert-danger">@Model.Errore</div> }
                <form method="post">
                    <div class="mb-3">
                        <label class="form-label">Username</label>
                        <input type="text" asp-for="Username" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" asp-for="Email" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Password</label>
                        <input type="password" asp-for="Password" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Conferma Password</label>
                        <input type="password" asp-for="ConfermaPassword" class="form-control" required />
                    </div>
                    <button type="submit" class="btn btn-success w-100">Registrati</button>
                </form>
                <p class="text-center mt-3 mb-0 small">Hai gia' un account? <a href="/Account/Login">Accedi</a></p>
            </div>
        </div>
    </div>
</div>
