@page
@model PartiteModel
@{
    ViewData["Title"] = "Partite Serie A";

    bool hasData = false;
    var fixtures = new System.Text.Json.JsonElement();

    if (Model.Partite.ValueKind != System.Text.Json.JsonValueKind.Undefined
        && Model.Partite.TryGetProperty("data", out var fixturesEl)
        && fixturesEl.ValueKind == System.Text.Json.JsonValueKind.Array)
    {
        fixtures = fixturesEl;
        hasData = fixturesEl.GetArrayLength() > 0;
    }
}

<h4 class="mb-3 fw-bold">&#128197; Serie A &mdash; Partite</h4>

<form method="get" class="d-flex gap-2 mb-4">
    <input type="date" name="data" value="@Model.DataSelezionata" class="form-control" style="max-width:200px;" />
    <button type="submit" class="btn btn-success">Cerca</button>
    <a href="/Partite" class="btn btn-outline-secondary">Oggi</a>
</form>

@if (!string.IsNullOrEmpty(Model.Errore))
{
    <div class="alert alert-warning">@Model.Errore</div>
}
else if (!hasData)
{
    <div class="alert alert-info">Nessuna partita di Serie A trovata per questa data.</div>
}
else
{
    <div class="row">
        @foreach (var f in fixtures.EnumerateArray())
        {
            string nome = f.TryGetProperty("name", out var n) ? n.GetString() ?? "" : "";
            string[] sq = nome.Split(" vs ");
            string homeName = sq.Length > 0 ? sq[0] : "Casa";
            string awayName = sq.Length > 1 ? sq[1] : "Ospite";
            string homeLogo = "", awayLogo = "";
            int homeScore = 0, awayScore = 0;
            bool hasScore = false;
            string orario = "", statoLabel = "", statoBadge = "bg-secondary";

            if (f.TryGetProperty("participants", out var parts))
            {
                foreach (var part in parts.EnumerateArray())
                {
                    bool isHome = part.TryGetProperty("meta", out var meta)
                    && meta.TryGetProperty("location", out var loc)
                    && loc.GetString() == "home";
                    string pLogo = part.TryGetProperty("image_path", out var img) ? img.GetString() ?? "" : "";
                    if (isHome) homeLogo = pLogo; else awayLogo = pLogo;
                }
            }

            if (f.TryGetProperty("scores", out var scores) && scores.GetArrayLength() > 0)
            {
                hasScore = true;
                foreach (var s in scores.EnumerateArray())
                {
                    if (!s.TryGetProperty("description", out var desc) || desc.GetString() != "CURRENT") continue;
                    if (!s.TryGetProperty("score", out var sc)) continue;
                    string par = sc.TryGetProperty("participant", out var pp) ? pp.GetString() ?? "" : "";
                    int goals = sc.TryGetProperty("goals", out var g) ? g.GetInt32() : 0;
                    if (par == "home") homeScore = goals; else awayScore = goals;
                }
            }

            if (f.TryGetProperty("starting_at", out var sa))
            {
                string saStr = sa.GetString() ?? "";
                if (saStr.Length >= 16) orario = saStr[11..16];
            }

            if (f.TryGetProperty("state", out var state) && state.TryGetProperty("name", out var stName))
            {
                string st = stName.GetString() ?? "";
                statoLabel = st switch
                {
                    "FT" => "Finita",
                    "NS" => "Non iniziata",
                    "HT" => "Intervallo",
                    "1H" or "2H" => "LIVE",
                    _ => st
                };
                statoBadge = st switch
                {
                    "FT" => "bg-secondary",
                    "NS" => "bg-info text-dark",
                    "1H" or "2H" or "HT" => "bg-danger",
                    _ => "bg-secondary"
                };
            }

            <div class="col-lg-4 col-md-6 mb-3">
                <div class="card shadow-sm h-100">
                    <div class="card-header text-white d-flex justify-content-between align-items-center"
                         style="background:#1a7a3c;font-size:12px;">
                        <span>Serie A</span>
                        <span class="badge @statoBadge">
                            @(string.IsNullOrEmpty(statoLabel) ? orario : statoLabel)
                        </span>
                    </div>
                    <div class="card-body text-center py-3">
                        <div class="d-flex justify-content-around align-items-center">
                            <div style="width:90px;">
                                @if (!string.IsNullOrEmpty(homeLogo))
                                {
                                    <img src="@homeLogo" width="36" height="36" class="mb-1" />
                                    <br />
         }
                                <small class="fw-semibold" style="font-size:11px;">@homeName</small>
                            </div>
                            <div class="fw-bold px-2" style="font-size:22px;">
                                @if (hasScore)
                                {
                                    @($"{homeScore} - {awayScore}")
                                }
                                else
                                {

                                    <span class="text-muted fs-6">@orario</span>
                                }
                            </div>
                            <div style="width:90px;">
                                @if (!string.IsNullOrEmpty(awayLogo))
                                {
                                    <img src="@awayLogo" width="36" height="36" class="mb-1" />
                                    <br />
         }
                                <small class="fw-semibold" style="font-size:11px;">@awayName</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}