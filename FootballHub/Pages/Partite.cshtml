@page
@model PartiteModel
@using System.Text.Json

@{
    ViewData["Title"] = "Partite";

    bool hasData = false;
    JsonElement leghe = default;

    if (Model.Partite.ValueKind != JsonValueKind.Undefined &&
        Model.Partite.TryGetProperty("data", out leghe) &&
        leghe.ValueKind == JsonValueKind.Array)
    {
        hasData = true;
    }
}

<h4 class="mb-3 fw-bold">&#128197; Partite per Data</h4>

<form method="get" class="d-flex gap-2 mb-4">
    <input type="date" name="data" value="@Model.DataSelezionata" class="form-control" style="max-width:200px;" />
    <button type="submit" class="btn btn-success">Cerca</button>
</form>

@if (!string.IsNullOrEmpty(Model.Errore))
{
    <div class="alert alert-warning">@Model.Errore</div>
}
else if (hasData && leghe.GetArrayLength() > 0)
{
    foreach (var lega in leghe.EnumerateArray())
    {
        string legaNome = lega.TryGetProperty("name", out var ln) ? ln.GetString() ?? "" : "";
        string legaLogo = lega.TryGetProperty("image_path", out var li) ? li.GetString() ?? "" : "";

        if (!lega.TryGetProperty("today", out var matches) || matches.ValueKind != JsonValueKind.Array || matches.GetArrayLength() == 0)
            continue;

        <div class="mb-4">
            <div class="d-flex align-items-center gap-2 mb-2">
                @if (!string.IsNullOrEmpty(legaLogo))
                {
                    <img src="@legaLogo" width="24" height="24" />
                }
                <h6 class="fw-bold mb-0">@legaNome</h6>
            </div>

            <div class="row">
                @foreach (var m in matches.EnumerateArray())
                {
                    string homeName = "Casa", awayName = "Ospite";
                    string homeLogo = "", awayLogo = "";
                    int homeScore = 0, awayScore = 0;
                    bool started = false;
                    string orario = "";

                    if (m.TryGetProperty("participants", out var parts) && parts.ValueKind == JsonValueKind.Array)
                    {
                        foreach (var part in parts.EnumerateArray())
                        {
                            bool isHome = part.TryGetProperty("meta", out var meta)
                            && meta.TryGetProperty("location", out var loc)
                            && loc.GetString() == "home";

                            string pn = part.TryGetProperty("name", out var pnn) ? pnn.GetString() ?? "" : "";
                            string pl = part.TryGetProperty("image_path", out var pli) ? pli.GetString() ?? "" : "";

                            if (isHome)
                            {
                                homeName = pn;
                                homeLogo = pl;
                            }
                            else
                            {
                                awayName = pn;
                                awayLogo = pl;
                            }
                        }
                    }

                    if (m.TryGetProperty("scores", out var scores) && scores.ValueKind == JsonValueKind.Array)
                    {
                        started = true;

                        foreach (var s in scores.EnumerateArray())
                        {
                            if (!s.TryGetProperty("description", out var desc) || desc.GetString() != "CURRENT")
                                continue;

                            if (!s.TryGetProperty("score", out var sc))
                                continue;

                            string par = sc.TryGetProperty("participant", out var pp) ? pp.GetString() ?? "" : "";
                            int goals = sc.TryGetProperty("goals", out var g) ? g.GetInt32() : 0;

                            if (par == "home") homeScore = goals;
                            else if (par == "away") awayScore = goals;
                        }
                    }

                    if (m.TryGetProperty("starting_at", out var sa))
                    {
                        string saStr = sa.GetString() ?? "";
                        if (saStr.Length >= 16)
                            orario = saStr.Substring(11, 5);
                    }

                    <div class="col-lg-4 col-md-6 mb-2">
                        <div class="card shadow-sm">
                            <div class="card-body text-center py-2">
                                <div class="d-flex justify-content-around align-items-center">

                                    <div style="width:80px;">
                                        @if (!string.IsNullOrEmpty(homeLogo))
                                        {
                                            <img src="@homeLogo" width="30" height="30" class="mb-1" />
                            
                                            <br />
                                        }
                                        <small class="fw-semibold" style="font-size:11px;">@homeName</small>
                                    </div>

                                    <div class="px-2">
                                        @if (started)
                                        {
                                            <span class="fs-5 fw-bold">@homeScore - @awayScore</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted fw-semibold">@orario</span>
                                        }
                                    </div>

                                    <div style="width:80px;">
                                        @if (!string.IsNullOrEmpty(awayLogo))
                                        {
                                            <img src="@awayLogo" width="30" height="30" class="mb-1" />
                            
                                            <br />
                                        }
                                        <small class="fw-semibold" style="font-size:11px;">@awayName</small>
                                    </div>

                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
}
else
{
    <div class="alert alert-info">Nessuna partita trovata per questa data.</div>
}