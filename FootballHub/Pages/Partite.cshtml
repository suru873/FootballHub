@page
@model HubCalcio.Pages.PartiteModel
@{
    ViewData["Title"] = "Calendario Superliga Danese";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <div>
            <h2 class="mb-0"><i class="bi bi-calendar3 text-primary"></i> Superliga Danese</h2>
            <small class="text-muted">Risultati e calendari per la stagione attuale</small>
        </div>
        <form method="get" class="d-flex align-items-center">
            <input type="date" name="DataSelezionata" value="@Model.DataSelezionata"
                   class="form-control shadow-sm" onchange="this.form.submit()" />
        </form>
    </div>

    @if (Model.Partite.ValueKind == System.Text.Json.JsonValueKind.Array && Model.Partite.GetArrayLength() > 0)
    {
        <div class="row g-3">
            @foreach (var partita in Model.Partite.EnumerateArray())
            {
                // 1. ESTRAZIONE SICURA STATO (Risolve l'errore p.GetProperty("state"))
                string statoNome = "N/A";
                bool isLive = false;
                if (partita.TryGetProperty("state", out var stateProp) && stateProp.TryGetProperty("name", out var nameProp))
                {
                    statoNome = nameProp.GetString() ?? "N/A";
                    isLive = statoNome == "LIVE";
                }

                // 2. ESTRAZIONE NOME E CAMPIONATO
                string leagueName = "Superliga";
                if (partita.TryGetProperty("league", out var league) && league.TryGetProperty("name", out var ln))
                {
                    leagueName = ln.GetString() ?? "Superliga";
                }

                // 3. ESTRAZIONE PUNTEGGI DINAMICA
                int homeScore = 0;
                int awayScore = 0;
                if (partita.TryGetProperty("scores", out var scores))
                {
                    foreach (var s in scores.EnumerateArray())
                    {
                        if (s.TryGetProperty("description", out var desc) && desc.GetString() == "CURRENT")
                        {
                            if (s.TryGetProperty("score", out var sc) && s.TryGetProperty("participant", out var partSide))
                            {
                                int goals = sc.GetProperty("goals").GetInt32();
                                if (partSide.GetString() == "home") homeScore = goals; else awayScore = goals;
                            }
                        }
                    }
                }

                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm border-0">
                        <div class="card-header bg-light d-flex justify-content-between py-2 border-0">
                            <small class="text-muted fw-bold">@leagueName</small>
                            <span class="badge @(isLive ? "bg-danger animate-pulse" : "bg-secondary")">
                                @statoNome
                            </span>
                        </div>
                        <div class="card-body py-4">
                            <div class="d-flex justify-content-around align-items-center">
                                @if (partita.TryGetProperty("participants", out var participants))
                                {
                                    foreach (var team in participants.EnumerateArray())
                                    {
                                        var isHome = team.GetProperty("meta").GetProperty("location").GetString() == "home";
                                        <div class="text-center" style="width: 40%;">
                                            <img src="@team.GetProperty("image_path").GetString()" class="mb-2" style="height: 45px;" />
                                            <div class="small fw-bold text-truncate">@team.GetProperty("name").GetString()</div>
                                            <h3 class="mt-2 mb-0">@(isHome? homeScore : awayScore)</h3>
                                        </div>
                                        if (isHome)
                                        {

                                            <div class="text-muted fs-4">-</div>
                                        }
                                    }
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info text-center py-5 shadow-sm border-0">
            <i class="bi bi-info-circle display-4 d-block mb-3 text-secondary"></i>
            <h5>Nessuna partita trovata</h5>
            <p class="mb-0">Non ci sono eventi per la Superliga Danese nella data selezionata (@Model.DataSelezionata).</p>
        </div>
    }
</div>

<style>
    .animate-pulse {
        animation: pulse-red 2s infinite;
    }

    @@keyframes pulse-red {
        0% {
            opacity: 1;
        }

        50% {
            opacity: 0.5;
        }

        100% {
            opacity: 1;
        }
    }

    .card {
        transition: transform 0.2s;
    }

        .card:hover {
            transform: translateY(-5px);
        }
</style>