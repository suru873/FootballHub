@page
@using System.Text.Json
@model HubCalcio.ClassificaModel
@{
    ViewData["Title"] = "Classifica Superliga Danese";
}

<div class="container mt-4">
    <h2 class="mb-4"><i class="bi bi-trophy-fill text-warning"></i> Classifica Superliga</h2>

    @if (!string.IsNullOrEmpty(Model.Errore))
    {
        <div class="alert alert-danger shadow-sm">
            <strong>Errore:</strong> @Model.Errore
        </div>
    }
    else if (Model.Classifica.ValueKind == JsonValueKind.Array)
    {
        <div class="table-responsive shadow rounded">
            <table class="table table-hover align-middle mb-0 bg-white">
                <thead class="table-dark">
                    <tr>
                        <th class="text-center">Pos</th>
                        <th>Squadra</th>
                        <th class="text-center">PT</th>
                        <th class="text-center">G</th>
                        <th class="text-center text-success">V</th>
                        <th class="text-center text-secondary">N</th>
                        <th class="text-center text-danger">P</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model.Classifica.EnumerateArray())
                    {
                        var team = row.TryGetProperty("participant", out var p) ? p : default;
                        var details = row.TryGetProperty("details", out var d) ? d : default;

                        // Funzione corretta per Sportmonks v3
                        int GetStat(int typeId)
                        {
                            if (details.ValueKind != JsonValueKind.Array) return 0;
                            var stat = details.EnumerateArray().FirstOrDefault(x =>
                            x.TryGetProperty("type_id", out var t) && t.GetInt32() == typeId);

                            return stat.ValueKind != JsonValueKind.Undefined && stat.TryGetProperty("value", out var v)
                            ? v.GetInt32() : 0;
                        }

                        <tr>
                            <td class="text-center fw-bold">@row.GetProperty("position").GetInt32()</td>
                            <td>
                                <img src="@team.GetProperty("image_path").GetString()" width="25" class="me-2" />
                                <strong>@team.GetProperty("name").GetString()</strong>
                            </td>
                            <td class="text-center fw-bold text-primary">@row.GetProperty("points").GetInt32()</td>
                            @* 129=Giocate, 130=Vinte, 131=Pareggi, 132=Perse *@
                            <td class="text-center">@GetStat(129)</td>
                            <td class="text-center">@GetStat(130)</td>
                            <td class="text-center">@GetStat(131)</td>
                            <td class="text-center">@GetStat(132)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>