@page
@model IndexModel
@{
    ViewData["Title"] = "Partite Live";
}

<h4 class="mb-3 fw-bold">&#128308; Partite in Diretta</h4>

@if (!string.IsNullOrEmpty(Model.Errore))
{
    <div class="alert alert-warning">@Model.Errore</div>
}
else
{
    System.Text.Json.JsonElement partite = default;
    bool hasData = Model.Livescores.ValueKind != System.Text.Json.JsonValueKind.Undefined
                && Model.Livescores.TryGetProperty("data", out partite);

    if (hasData && partite.ValueKind == System.Text.Json.JsonValueKind.Array && partite.GetArrayLength() > 0)
    {
        <div class="row">
        @foreach (var p in partite.EnumerateArray())
        {
            string homeName = "Casa", awayName = "Ospite";
            string homeLogo = "", awayLogo = "";
            int homeScore = 0, awayScore = 0;
            string leagueName = "";
            string minuto = "";

            if (p.TryGetProperty("participants", out var parts))
            {
                foreach (var part in parts.EnumerateArray())
                {
                    bool isHome = part.TryGetProperty("meta", out var meta)
                               && meta.TryGetProperty("location", out var loc)
                               && loc.GetString() == "home";
                    string pName = part.TryGetProperty("name", out var n) ? n.GetString() ?? "" : "";
                    string pLogo = part.TryGetProperty("image_path", out var img) ? img.GetString() ?? "" : "";
                    if (isHome) { homeName = pName; homeLogo = pLogo; }
                    else { awayName = pName; awayLogo = pLogo; }
                }
            }

            if (p.TryGetProperty("scores", out var scores))
            {
                foreach (var s in scores.EnumerateArray())
                {
                    bool isHome = s.TryGetProperty("score", out var sc)
                               && s.TryGetProperty("description", out var desc)
                               && desc.GetString() == "CURRENT";
                    if (isHome && s.TryGetProperty("score", out var scoreObj))
                    {
                        if (scoreObj.TryGetProperty("participant", out var par))
                        {
                            if (par.GetString() == "home" && scoreObj.TryGetProperty("goals", out var hg))
                                homeScore = hg.GetInt32();
                            if (par.GetString() == "away" && scoreObj.TryGetProperty("goals", out var ag))
                                awayScore = ag.GetInt32();
                        }
                    }
                }
            }

            if (p.TryGetProperty("league", out var league) && league.TryGetProperty("name", out var ln))
                leagueName = ln.GetString() ?? "";

            if (p.TryGetProperty("periods", out var periods))
            {
                foreach (var per in periods.EnumerateArray())
                {
                    if (per.TryGetProperty("ticking", out var tick) && tick.GetBoolean()
                     && per.TryGetProperty("minutes", out var mins))
                        minuto = mins.GetInt32() + "'";
                }
            }

            <div class="col-lg-4 col-md-6 mb-3">
                <div class="card shadow-sm h-100 border-danger">
                    <div class="card-header text-white d-flex justify-content-between align-items-center"
                         style="background-color:#1a7a3c; font-size:12px;">
                        <span>@leagueName</span>
                        <span class="badge bg-danger">LIVE @minuto</span>
                    </div>
                    <div class="card-body text-center">
                        <div class="d-flex justify-content-around align-items-center my-2">
                            <div class="text-center">
                                @if (!string.IsNullOrEmpty(homeLogo))
                                {
                                    <img src="@homeLogo" width="40" height="40" class="mb-1" />
                                }
                                <br/><small class="fw-semibold">@homeName</small>
                            </div>
                            <div class="fs-2 fw-bold px-2">@homeScore - @awayScore</div>
                            <div class="text-center">
                                @if (!string.IsNullOrEmpty(awayLogo))
                                {
                                    <img src="@awayLogo" width="40" height="40" class="mb-1" />
                                }
                                <br/><small class="fw-semibold">@awayName</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <strong>Nessuna partita in diretta al momento.</strong><br/>
            <a href="/Partite" class="btn btn-success mt-2">Vedi le partite di oggi</a>
        </div>
    }
}
         