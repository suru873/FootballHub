@page
@using System.Text.Json
@model IndexModel
@{
    ViewData["Title"] = "Home - Superliga Danese";
}

<div class="container mt-4">
    @* Intestazione *@
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <h4 class="fw-bold mb-0">SUPERLIGA DANESE LIVE</h4>
        <a href="/Partite" class="btn btn-sm btn-outline-primary">Calendario</a>
    </div>

    @* Se esiste un errore nel Model, lo mostriamo *@
    @if (!string.IsNullOrEmpty(Model.Errore))
    {
        <div class="alert alert-warning">@Model.Errore</div>
    }

    @* Ciclo delle partite *@
    <div class="row">
        @if (Model.Livescores.ValueKind == JsonValueKind.Array && Model.Livescores.GetArrayLength() > 0)
        {
            @foreach (var p in Model.Livescores.EnumerateArray())
            {
                // Estrazione dati sicura
                string nome = p.TryGetProperty("name", out var n) ? n.GetString() : "Gara";
                string homeLogo = "";
                string awayLogo = "";

                // Logica per i loghi (semplificata per stabilit‡)
                if (p.TryGetProperty("participants", out var parts))
                {
                    foreach (var part in parts.EnumerateArray())
                    {
                        var loc = part.GetProperty("meta").GetProperty("location").GetString();
                        var img = part.GetProperty("image_path").GetString();
                        if (loc == "home") homeLogo = img; else awayLogo = img;
                    }
                }

                <div class="col-md-4 mb-4">
                    <div class="card shadow-sm border-0">
                        <div class="card-body text-center">
                            <div class="d-flex justify-content-between align-items-center">
                                <img src="@homeLogo" width="40">
                                <span class="fw-bold">VS</span>
                                <img src="@awayLogo" width="40">
                            </div>
                            <div class="mt-2 small fw-bold">@nome</div>
                        </div>
                    </div>
                </div>
            }
        }
        else if (string.IsNullOrEmpty(Model.Errore))
        {
            <div class="col-12 text-center">
                <p class="text-muted">Nessuna partita disponibile per oggi.</p>
            </div>
        }
    </div>
</div>