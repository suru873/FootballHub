@page
@using System.Text.Json
@model FootballHub.Pages.PronosticiModel
@{
    ViewData["Title"] = "Pronostici Superliga";
}

<div class="container mt-4">
    <div class="mb-4">
        <h2 class="fw-bold"><i class="bi bi-magic text-purple"></i> Pronostici Superliga</h2>
        <p class="text-muted">Analisi e consigli basati sulle quote live di oggi.</p>
    </div>

    @if (!string.IsNullOrEmpty(Model.Errore))
    {
        <div class="alert alert-warning border-0 shadow-sm">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @Model.Errore
        </div>
    }

    @* PROTEZIONE: Verifica se PartiteConQuote č un array valido *@
    @if (Model.PartiteConQuote.ValueKind == JsonValueKind.Array && Model.PartiteConQuote.GetArrayLength() > 0)
    {
        <div class="row">
            @foreach (var p in Model.PartiteConQuote.EnumerateArray())
            {
                string nome = p.TryGetProperty("name", out var n) ? n.GetString() ?? "" : "Gara";

                <div class="col-md-6 mb-4">
                    <div class="card h-100 shadow-sm border-0">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="badge bg-light text-dark border">Superliga Danese</span>
                                <span class="text-muted small"><i class="bi bi-clock"></i> Oggi</span>
                            </div>

                            <h5 class="card-title fw-bold text-center mb-4">@nome</h5>

                            <div class="bg-light p-3 rounded mb-3">
                                <h6 class="fw-bold text-uppercase small text-muted mb-2">Suggerimento AI</h6>
                                <div class="d-flex align-items-center">
                                    <i class="bi bi-lightbulb-fill text-warning fs-4 me-2"></i>
                                    @* Logica simulata del pronostico *@
                                    <span class="fw-bold text-success">Esito consigliato: 1X + Over 1.5</span>
                                </div>
                            </div>

                            <div class="row text-center g-2">
                                <div class="col-4">
                                    <div class="border rounded py-2">
                                        <small class="d-block text-muted">1</small>
                                        <span class="fw-bold">2.10</span>
                                    </div>
                                </div>
                                <div class="col-4">
                                    <div class="border rounded py-2">
                                        <small class="d-block text-muted">X</small>
                                        <span class="fw-bold">3.40</span>
                                    </div>
                                </div>
                                <div class="col-4">
                                    <div class="border rounded py-2">
                                        <small class="d-block text-muted">2</small>
                                        <span class="fw-bold">3.15</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer bg-white border-0 text-center pb-3">
                            <button class="btn btn-purple btn-sm w-100 rounded-pill">Vedi Analisi Dettagliata</button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5 bg-white shadow-sm rounded">
            <i class="bi bi-graph-up-arrow display-1 text-muted opacity-25"></i>
            <h5 class="mt-3 text-muted">Nessun pronostico disponibile al momento</h5>
            <p class="small text-muted">I dati delle quote per la Superliga Danese non sono ancora stati caricati.</p>
        </div>
    }
</div>

<style>
    .text-purple {
        color: #6f42c1;
    }

    .btn-purple {
        background-color: #6f42c1;
        color: white;
        transition: 0.3s;
    }

        .btn-purple:hover {
            background-color: #59359a;
            color: white;
            transform: scale(1.02);
        }

    .card {
        transition: all 0.3s ease;
    }

        .card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
        }
</style>